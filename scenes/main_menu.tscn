[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/main_menu.gd" id="1_menu"]

[node name="MainMenu" type="CanvasLayer"]
script = ExtResource("1_menu")

[node name="CenterContainer" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
custom_minimum_size = Vector2(320, 0)
alignment = 1

[node name="Title" type="Label" parent="CenterContainer/VBoxContainer"]
text = "Lantern Engine"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 48

[node name="Spacer" type="Control" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 24)

[node name="LightLabButton" type="Button" parent="CenterContainer/VBoxContainer"]
text = "Light Lab"
custom_minimum_size = Vector2(0, 48)

[node name="RandomGenButton" type="Button" parent="CenterContainer/VBoxContainer"]
text = "Random Gen"
custom_minimum_size = Vector2(0, 48)

[node name="PlaceholderLabel" type="Label" parent="CenterContainer/VBoxContainer"]
text = "(placeholder)"
horizontal_alignment = 1
modulate = Color(1, 1, 1, 0.5)

[connection signal="pressed" from="CenterContainer/VBoxContainer/LightLabButton" to="." method="_on_light_lab_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/RandomGenButton" to="." method="_on_random_gen_pressed"]
